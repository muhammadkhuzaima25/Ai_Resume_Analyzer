# Google OAuth (required for Google Sign-In buttons)
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# reCAPTCHA v3 Site Key (required for contact form spam protection)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Backend API URL (set this for production; leaves empty uses Vite proxy in dev)
VITE_API_URL=https://resumatchai-three.vercel.app
